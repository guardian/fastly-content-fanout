{
  "compilerOptions": {
    "esModuleInterop": true,
    "lib": [ "es2022" ],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "build",
    "rootDir": "src",
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "./src/**/*.js",
    "./src/**/*.ts",
  ],
  "exclude": [
    "node_modules"
  ]
}
